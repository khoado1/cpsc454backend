# Copy this file to .env.local and fill in your local secrets.
# MongoDB root credentials used by docker compose.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# App connection strings. Keep these in sync with the MongoDB root credentials above.
MONGODB_URI=mongodb://admin:password@localhost:27017/?authSource=admin
# Optional separate value for admin-only tasks such as create_user.py
MONGODB_WITH_CRED_URI=mongodb://admin:password@localhost:27017/?authSource=admin
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=replace_me_in_production
JWT_EXPIRES_MINUTES=60